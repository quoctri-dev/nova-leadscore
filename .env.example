# === REQUIRED (at least one AI key) ===
GOOGLE_AI_API_KEY=           # Get from: https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY=         # Get from: https://console.anthropic.com/api-keys
# GROQ_API_KEY=              # Get from: https://console.groq.com/keys

# === SWAPPABLE (see README Configuration) ===
LLM_MODEL=gemini/gemini-2.5-flash  # Options: claude-sonnet-4-6 | groq/llama3-70b-8192
# FALLBACK_LLM_MODEL=       # Auto-fallback when primary fails
# FALLBACK_LLM_API_KEY=     # Key for fallback model

# === OPTIONAL ===
MAX_LEADS=500                # Max leads per upload (cost control)
BATCH_SIZE=10                # Leads per AI call
EXPORT_FORMAT=csv            # Options: csv | xlsx
LOG_SINK=console             # Options: console | file
